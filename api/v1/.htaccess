# API v1 .htaccess
# Rutează toate request-urile către index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Detect environment - production uses /api/v1/, dev uses /fleet-management/api/v1/
    # RewriteBase is set dynamically based on environment
    # For production (fleetly.ro): /api/v1/
    # For development (localhost): /fleet-management/api/v1/
    
    # Try without explicit RewriteBase for better compatibility
    # RewriteBase /api/v1/
    
    # Allow CORS preflight
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ index.php [QSA,L]
    
    # Route all requests to index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Disable directory listing
Options -Indexes

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>
